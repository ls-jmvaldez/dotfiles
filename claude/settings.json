{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git stash list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git merge-base:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh api:*)",
      "Bash(jira:*)",
      "Bash(newrelic:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet run:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(ln:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.envrc)",
      "Read(credentials.json)",
      "Read(.credentials.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(settings.local.json)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"${f##*/}\" in .env.example|.env.sample|.env.template|*.example|*.sample|*.template) exit 0;; esac; case \"$f\" in */.env|*/.env.*|*/.envrc|*/credentials.json|*/.credentials.json|*.pem|*.key|*/settings.local.json) echo '{\"decision\":\"block\",\"reason\":\"Blocked: sensitive file\"}'; exit 0;; esac; exit 0; }",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-conflict.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pr-text-style.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pr-jira-links.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pr-attribution.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pr-comment-attribution.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pr-issue-comment-attribution.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pr-review-attribution.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pr-ai-attribution.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-env-symlink.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "skipAutoPermissionPrompt": true
}
